<?xml version="1.0" encoding="utf-8"?>
<!--
    CORREÇÕES APLICADAS NESTA VERSÃO:

    BUG 1 (mini-game vazio):
      - containerGame estava sendo populado antes de ter VISIBLE no código anterior.
        Corrigido no Kotlin (GameOverlayManager.kt).

    BUG 2 (botão Copiar sumiu):
      - containerCopyButtons usava layout_width="0dp" + layout_weight="1" dentro de um
        LinearLayout horizontal. Quando visibility vai de GONE→VISIBLE, o weight não
        é recalculado corretamente em overlay views. Corrigido para wrap_content sem weight.

    BUG 3 (✏️ EN não aparece no modo tradução):
      - btnEditOriginal estava sozinho na "Linha 2", abaixo do containerCopyButtons.
        Em algumas versões do Android a segunda linha era suprimida antes do layout pass.
        SOLUÇÃO: btnEditOriginal e btnEditTranslation ficam na MESMA linha horizontal,
        lado a lado, garantindo que ambos sejam renderizados no mesmo layout pass.
        O Kotlin controla qual é VISIBLE em cada modo.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EE1A1A2E"
        android:padding="16dp">

        <!-- ══ CABEÇALHO ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:padding="8dp" />

        </LinearLayout>

        <!-- ══ SAFE ZONE DO RELÓGIO ══ -->
        <View
            android:id="@+id/clockSafeZone"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:background="#22FFFFFF"
            android:visibility="gone" />

        <!-- ══ MODO TRADUÇÃO ══ -->
        <LinearLayout
            android:id="@+id/containerTranslation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvOriginal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:padding="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTranslation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="8dp" />

        </LinearLayout>

        <!-- ══ MODO GAME ══ -->
        <LinearLayout
            android:id="@+id/containerGame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="8dp" />

            <!-- Área de resposta do usuário (chips selecionados) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupAnswer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:background="#33FFFFFF"
                    android:padding="6dp"
                    app:singleLine="true" />

            </HorizontalScrollView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#555555"
                android:layout_marginVertical="8dp" />

            <!-- Banco de palavras disponíveis — maxHeight reduzido para caber os botões abaixo -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="110dp"
                android:scrollbars="vertical"
                android:fadeScrollbars="false"
                android:overScrollMode="never">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupWords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="4dp" />

            </ScrollView>

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:padding="8dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ══ SEPARADOR VISUAL ANTES DA BARRA DE AÇÕES ══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#44FFFFFF"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp" />

        <!-- ══ BARRA DE AÇÕES ══
             ESTRUTURA REORGANIZADA (BUG 2 + BUG 3):

             Linha A: [📋 EN] [🌐 PT]  ← botões de cópia (wrap_content, sem weight)
             Linha B: [✏️ EN] [✏️ PT] [✏️ Frase do jogo]  ← botões de edição, todos na mesma linha
             Linha C: [Pular ⏭] [Próxima frase ▶]  ← rodapé

             Todos os botões têm minWidth/minHeight para garantir área de toque.
             Visibilidade 100% controlada pelo Kotlin — todos começam como "gone".
        -->

        <!-- Linha A: Botões de cópia -->
        <!--
            BUG 2 FIX: layout_width="wrap_content" (era "0dp" com weight="1").
            O weight causava colapso em GONE→VISIBLE dentro de overlay views
            porque o LinearLayout pai não reprocessava o weight corretamente.
  g      -->
        <LinearLayout
            android:id="@+id/containerCopyButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnCopyOriginal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:minHeight="36dp"
                android:text="📋 EN"
                android:textColor="#AAAAFF"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="#33FFFFFF"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnCopyTranslation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:minHeight="36dp"
                android:text="🌐 PT"
                android:textColor="#AAFFAA"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="#33FFFFFF"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Linha B: Botões de edição (todos na mesma linha)
             BUG 3 FIX: btnEditOriginal (✏️ EN) e btnEditTranslation (✏️ PT)
             estão agora na MESMA linha horizontal.
             Antes, o EN estava em uma linha separada abaixo, que em alguns casos
             era suprimida pelo sistema antes do layout pass completar.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start|center_vertical"
            android:layout_marginBottom="4dp">

            <!-- ✏️ EN: corrigir texto original (ambos os modos) -->
            <TextView
                android:id="@+id/btnEditOriginal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="64dp"
                android:minHeight="36dp"
                android:text="✏️ EN"
                android:textColor="#88CCFF"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="#33FFFFFF"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <!-- ✏️ PT: corrigir tradução (modo tradução direta) -->
            <TextView
                android:id="@+id/btnEditTranslation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="64dp"
                android:minHeight="36dp"
                android:text="✏️ PT"
                android:textColor="#FFDD88"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="#33FFFFFF"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <!-- ✏️ Frase do jogo: corrigir PT para o mini-game -->
            <TextView
                android:id="@+id/btnEditGameSentence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="96dp"
                android:minHeight="36dp"
                android:text="✏️ Frase do jogo"
                android:textColor="#FFAA66"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="#33FFFFFF"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Linha C: Rodapé de navegação -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/btnSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pular ⏭"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:padding="10dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Próxima frase ▶"
                android:textColor="#BB86FC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="10dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>