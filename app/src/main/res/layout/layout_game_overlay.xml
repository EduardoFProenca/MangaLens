<?xml version="1.0" encoding="utf-8"?>
<!--
    CORREÇÕES DE CAUSA RAIZ NESTA VERSÃO:

    BUG 1 (mini-game vazio):
      Corrigido no Kotlin: filterForGameMode() não exige boundingBox != null.
      A função anterior descartava TODOS os blocos sem coordenadas de tela,
      que é o caso comum em captureAndProcess com isFullScreen=true.

    BUG 2 (botão Copiar sumiu):
      Corrigido no Kotlin: setupCopyButtons() é chamado no INÍCIO de setupGameMode(),
      não apenas após acerto/pulo. Também corrigido no XML: containerCopyButtons
      usa wrap_content sem weight, e fica numa linha isolada.

    BUG 3 (✏️ EN não aparece no modo tradução):
      CAUSA RAIZ: os botões de edição (Linha B) ficavam ABAIXO do
      containerCopyButtons (Linha A). Quando containerCopyButtons se tornava VISIBLE
      (com wrap_content), ele empurrava a Linha B para fora da área visível do painel.
      SOLUÇÃO: inverter a ordem — botões de edição PRIMEIRO, cópia DEPOIS.
      Assim, EN e PT de edição sempre têm espaço garantido no topo da barra de ações,
      independente do estado de visibilidade dos botões de cópia.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EE1A1A2E"
        android:padding="16dp">

        <!-- ══ CABEÇALHO ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:padding="8dp" />

        </LinearLayout>

        <!-- ══ SAFE ZONE DO RELÓGIO ══ -->
        <View
            android:id="@+id/clockSafeZone"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:background="#22FFFFFF"
            android:visibility="gone" />

        <!-- ══ MODO TRADUÇÃO ══ -->
        <LinearLayout
            android:id="@+id/containerTranslation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvOriginal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:padding="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTranslation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="8dp" />

        </LinearLayout>

        <!-- ══ MODO GAME ══ -->
        <LinearLayout
            android:id="@+id/containerGame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="8dp" />

            <!-- Área de resposta (chips selecionados pelo usuário) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupAnswer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:background="#33FFFFFF"
                    android:padding="6dp"
                    app:singleLine="true" />

            </HorizontalScrollView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#555555"
                android:layout_marginVertical="8dp" />

            <!-- Banco de palavras — maxHeight contido para não empurrar botões abaixo -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="100dp"
                android:scrollbars="vertical"
                android:fadeScrollbars="false"
                android:overScrollMode="never">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupWords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="4dp" />

            </ScrollView>

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:padding="8dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ══ SEPARADOR ══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#44FFFFFF"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp" />

        <!--
            ══ BARRA DE AÇÕES — ORDEM CORRIGIDA (BUG 3 FIX) ══

            NOVA ORDEM (de cima para baixo):
              1. Linha de EDIÇÃO  → ✏️ EN  |  ✏️ PT  |  ✏️ Frase do jogo
              2. Linha de CÓPIA   → 📋 EN  |  🌐 PT
              3. Rodapé           → Pular ⏭  |  Próxima frase ▶

            JUSTIFICATIVA:
            Os botões de edição ficam no TOPO da barra de ações, então
            nunca são empurrados para fora da tela pelo containerCopyButtons.
            O Kotlin controla qual botão é VISIBLE em cada modo — o layout
            apenas garante que todos estejam sempre no fluxo do documento.
        -->

        <!-- ── Linha 1: BOTÕES DE EDIÇÃO (sempre no topo) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start|center_vertical"
            android:layout_marginBottom="6dp">

            <!--
                btnEditOriginal (✏️ EN):
                Visível em AMBOS os modos (game e tradução).
                O Kotlin seta VISIBLE em setupGameMode e setupTranslationMode.
            -->
            <TextView
                android:id="@+id/btnEditOriginal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="64dp"
                android:minHeight="40dp"
                android:text="✏️ EN"
                android:textColor="#88CCFF"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp"
                android:background="#33FFFFFF"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <!--
                btnEditTranslation (✏️ PT):
                Visível apenas no modo tradução direta.
                O Kotlin seta GONE em setupGameMode e VISIBLE em setupTranslationMode.
            -->
            <TextView
                android:id="@+id/btnEditTranslation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="64dp"
                android:minHeight="40dp"
                android:text="✏️ PT"
                android:textColor="#FFDD88"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp"
                android:background="#33FFFFFF"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <!--
                btnEditGameSentence (✏️ Frase do jogo):
                Visível apenas no modo game.
                O Kotlin seta VISIBLE em setupGameMode e GONE em setupTranslationMode.
            -->
            <TextView
                android:id="@+id/btnEditGameSentence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="96dp"
                android:minHeight="40dp"
                android:text="✏️ Frase do jogo"
                android:textColor="#FFAA66"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp"
                android:background="#33FFFFFF"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ── Linha 2: BOTÕES DE CÓPIA ── -->
        <!--
            containerCopyButtons: wrap_content sem weight.
            Fica ABAIXO dos botões de edição, então nunca interfere na visibilidade deles.
        -->
        <LinearLayout
            android:id="@+id/containerCopyButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnCopyOriginal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:minHeight="36dp"
                android:text="📋 EN"
                android:textColor="#AAAAFF"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="#33FFFFFF"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnCopyTranslation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:minHeight="36dp"
                android:text="🌐 PT"
                android:textColor="#AAFFAA"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="#33FFFFFF"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ── Linha 3: RODAPÉ DE NAVEGAÇÃO ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/btnSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pular ⏭"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:padding="10dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Próxima frase ▶"
                android:textColor="#BB86FC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="10dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>