<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#EE1A1A2E"
    android:padding="16dp">

    <!-- ══ CABEÇALHO ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:padding="8dp" />

    </LinearLayout>

    <!-- ══ SAFE ZONE DO RELÓGIO ══ -->
    <View
        android:id="@+id/clockSafeZone"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:background="#22FFFFFF"
        android:visibility="gone" />

    <!-- ══ MODO TRADUÇÃO ══ -->
    <LinearLayout
        android:id="@+id/containerTranslation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvOriginal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:padding="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvTranslation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="8dp" />

    </LinearLayout>

    <!-- ══ MODO GAME ══ -->
    <LinearLayout
        android:id="@+id/containerGame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupAnswer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:background="#33FFFFFF"
                android:padding="6dp"
                app:singleLine="true"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#555555"
            android:layout_marginVertical="8dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="160dp"
            android:scrollbars="vertical"
            android:fadeScrollbars="false"
            android:overScrollMode="never">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupWords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp" />

        </ScrollView>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:padding="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ══ BOTÕES DE CÓPIA ══
         Aparecem no modo tradução sempre, e no modo game após acerto/pulo -->
    <LinearLayout
        android:id="@+id/containerCopyButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/btnCopyOriginal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 EN"
            android:textColor="#AAAAFF"
            android:textSize="12sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:background="#33FFFFFF"
            android:layout_marginEnd="8dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnCopyTranslation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐 PT"
            android:textColor="#AAFFAA"
            android:textSize="12sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:background="#33FFFFFF"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ══ RODAPÉ: Pular + Próxima frase ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pular ⏭"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:padding="10dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Próxima frase ▶"
            android:textColor="#BB86FC"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>