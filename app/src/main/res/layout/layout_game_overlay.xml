<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#EE1A1A2E"
    android:padding="16dp">

    <!-- ══ CABEÇALHO ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:padding="8dp" />

    </LinearLayout>

    <!-- ══ SAFE ZONE DO RELÓGIO ══ -->
    <View
        android:id="@+id/clockSafeZone"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:background="#22FFFFFF"
        android:visibility="gone" />

    <!-- ══ MODO TRADUÇÃO ══ -->
    <LinearLayout
        android:id="@+id/containerTranslation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvOriginal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:padding="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvTranslation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="8dp" />

    </LinearLayout>

    <!-- ══ MODO GAME ══ -->
    <LinearLayout
        android:id="@+id/containerGame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupAnswer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:background="#33FFFFFF"
                android:padding="6dp"
                app:singleLine="true"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#555555"
            android:layout_marginVertical="8dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="160dp"
            android:scrollbars="vertical"
            android:fadeScrollbars="false"
            android:overScrollMode="never">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupWords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp" />

        </ScrollView>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:padding="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ══ BARRA DE AÇÕES ══
         Linha 1: Cópia | Editar PT
         Linha 2: Editar EN original | Editar frase do jogo
    -->

    <!-- Linha 1: cópia + editar tradução PT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start|center_vertical"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:id="@+id/containerCopyButtons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnCopyOriginal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 EN"
                android:textColor="#AAAAFF"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="#33FFFFFF"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnCopyTranslation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌐 PT"
                android:textColor="#AAFFAA"
                android:textSize="12sp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="#33FFFFFF"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Editar tradução PT (modo tradução) -->
        <TextView
            android:id="@+id/btnEditTranslation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️ PT"
            android:textColor="#FFDD88"
            android:textSize="12sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:background="#33FFFFFF"
            android:layout_marginStart="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Linha 2: editar EN + editar frase do jogo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start|center_vertical"
        android:layout_marginTop="4dp">

        <!-- Editar texto original EN (ambos os modos) -->
        <TextView
            android:id="@+id/btnEditOriginal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️ EN"
            android:textColor="#88CCFF"
            android:textSize="12sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:background="#33FFFFFF"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <!-- Editar frase PT do mini-game (só no modo game) -->
        <TextView
            android:id="@+id/btnEditGameSentence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️ Frase do jogo"
            android:textColor="#FFAA66"
            android:textSize="12sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:background="#33FFFFFF"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ══ RODAPÉ ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pular ⏭"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:padding="10dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Próxima frase ▶"
            android:textColor="#BB86FC"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>