<?xml version="1.0" encoding="utf-8"?>
<!--
    CORREÇÕES NESTA VERSÃO:

    BUG 1 — Jogo vazio:
      Corrigido no Kotlin: removido o early-return `if (words.size <= 1) return`
      em buildGameChips. Agora frases de 1 palavra criam 1 chip para tocar.

    BUG 1b — Next não funciona:
      Corrigido no Kotlin: setupCompletionButton agora chama onDismiss() quando
      hasNext=false, em vez de não fazer nada. Clicar em "✓ Concluído" fecha.

    BUG 2 — Relógio/bateria no jogo:
      Corrigido no Kotlin: filterForGameMode filtra padrões "9:41" e "84%".

    BUG 3/4 — ✏️ EN invisível no modo tradução:
      CAUSA RAIZ DE LAYOUT: os botões de edição ficavam ABAIXO do bloco de
      tradução (containerTranslation) no XML. O overlay cresce de baixo para
      cima (gravity=BOTTOM). Se o texto de tradução for longo, o overlay ocupa
      quase a tela inteira e os botões de edição ficam acima da parte visível.

      CORREÇÃO DE LAYOUT: mover os botões de edição para ANTES dos containers
      de conteúdo. Assim eles ficam na parte INFERIOR do overlay (perto da
      borda inferior da tela), sempre visíveis — independente do tamanho do
      texto acima.

    NOVA ORDEM DOS ELEMENTOS (de baixo para cima na tela, já que gravity=BOTTOM):
      [navegação]       → na parte mais inferior (visível)
      [cópia]           → logo acima
      [EDIÇÃO ✏️]       → AQUI (movido para ser sempre visível)
      [separador]
      [conteúdo]        → tradução ou jogo (pode crescer para cima)
      [safe zone]
      [cabeçalho]       → pode ficar fora da tela se o conteúdo for longo
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EE1A1A2E"
        android:padding="16dp">

        <!-- ══ CABEÇALHO ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:padding="8dp" />

        </LinearLayout>

        <!-- ══ SAFE ZONE ══ -->
        <View
            android:id="@+id/clockSafeZone"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:background="#22FFFFFF"
            android:visibility="gone" />

        <!-- ══ CONTEÚDO: MODO TRADUÇÃO ══ -->
        <LinearLayout
            android:id="@+id/containerTranslation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvOriginal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:padding="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTranslation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:padding="8dp" />

        </LinearLayout>

        <!-- ══ CONTEÚDO: MODO GAME ══ -->
        <LinearLayout
            android:id="@+id/containerGame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="8dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupAnswer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:background="#33FFFFFF"
                    android:padding="6dp"
                    app:singleLine="true" />

            </HorizontalScrollView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#555555"
                android:layout_marginVertical="8dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="100dp"
                android:scrollbars="vertical"
                android:fadeScrollbars="false"
                android:overScrollMode="never">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupWords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="4dp" />

            </ScrollView>

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:padding="8dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ══ SEPARADOR ══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#44FFFFFF"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp" />

        <!--
            ══ BOTÕES DE EDIÇÃO — POSICIONADOS ANTES DA CÓPIA E NAVEGAÇÃO ══

            JUSTIFICATIVA DO POSICIONAMENTO:
            O overlay usa gravity=BOTTOM. O LinearLayout cresce para CIMA a
            partir da borda inferior da tela. Portanto:
              - Últimos elementos no XML → mais próximos da borda inferior → sempre visíveis
              - Primeiros elementos no XML → podem ficar fora da tela se conteúdo for longo

            Os botões de edição (✏️ EN, ✏️ PT, ✏️ Frase) precisam ser sempre visíveis.
            Por isso ficam DEPOIS do conteúdo no XML, garantindo posição baixa no overlay.

            Os três botões ficam na mesma linha horizontal:
              - GONE não ocupa espaço → sem interferência entre modos
              - ✏️ EN → visível em ambos os modos
              - ✏️ PT → visível só no modo tradução
              - ✏️ Frase → visível só no modo game
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start|center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/btnEditOriginal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:minHeight="40dp"
                android:text="✏️ EN"
                android:textColor="#88CCFF"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp"
                android:background="#33FFFFFF"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnEditTranslation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:minHeight="40dp"
                android:text="✏️ PT"
                android:textColor="#FFDD88"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp"
                android:background="#33FFFFFF"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnEditGameSentence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="96dp"
                android:minHeight="40dp"
                android:text="✏️ Frase"
                android:textColor="#FFAA66"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp"
                android:background="#33FFFFFF"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ══ BOTÕES DE CÓPIA ══ -->
        <LinearLayout
            android:id="@+id/containerCopyButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnCopyOriginal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:minHeight="36dp"
                android:text="📋 EN"
                android:textColor="#AAAAFF"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="#33FFFFFF"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnCopyTranslation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:minHeight="36dp"
                android:text="🌐 PT"
                android:textColor="#AAFFAA"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="#33FFFFFF"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ══ NAVEGAÇÃO ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/btnSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pular ⏭"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:padding="10dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Próxima frase ▶"
                android:textColor="#BB86FC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="10dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>